---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
// TOC lists h2 headings only, matching the site's post conventions
const toc = headings.filter((h) => h.depth === 2);
---

<Base title={`${post.data.title} — 0xDiyor`} description={post.data.description}>
  <a href="/blog/" class="post-back">../blog</a>
  <article>
    <div class="post-header">
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <FormattedDate date={post.data.date} />
        {post.data.tags.map((tag) => <span class="post-tag">{tag}</span>)}
      </div>
    </div>

    {
      toc.length > 0 && (
        <details class="post-toc" open>
          <summary>Table of Contents</summary>
          <ol>
            {toc.map((h) => (
              <li>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ol>
        </details>
      )
    }

    <div class="post-content">
      <Content />
    </div>
  </article>
</Base>
