---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import AsciiBanner from '../components/AsciiBanner.astro';
import PostItem from '../components/PostItem.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { fetchAllProjects } from '../data/projects';
import { fetchRepoMeta } from '../data/github';

const posts = (await getCollection('blog'))
  .sort((a, b) => +b.data.date - +a.data.date)
  .slice(0, 5);
const projects = (await fetchAllProjects()).slice(0, 3);
const repoMeta = await fetchRepoMeta();
---

<Base>
  <AsciiBanner />

  <div class="home-section">
    <h2 class="section-title">Recent Writeups</h2>
    <ul class="post-list">
      {posts.map((post) => <PostItem post={post} />)}
    </ul>
  </div>

  <div class="home-section">
    <h2 class="section-title">Recent Projects</h2>
    <div class="project-grid">
      {projects.map((project) => (
        <ProjectCard
          project={project}
          meta={project.github ? repoMeta.get(project.github.toLowerCase()) ?? null : null}
        />
      ))}
    </div>
  </div>
</Base>
