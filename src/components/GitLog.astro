---
import { fetchRecentCommits } from '../data/github';

interface Props {
  limit?: number;
}

const { limit = 8 } = Astro.props;
const commits = await fetchRecentCommits(limit);
---

{
  commits.length > 0 && (
    <div>
      <h2 class="section-title">Recent Activity</h2>
      <div class="gitlog">
        <div class="gitlog-cmd">git log --all --oneline</div>
        <ul>
          {commits.map((c) => (
            <li>
              <a href={c.url} target="_blank" rel="noopener noreferrer" class="gitlog-sha">
                {c.shortSha}
              </a>
              <time datetime={c.date}>{c.date}</time>
              <span class="gitlog-repo">{c.repo}</span>
              <span class="gitlog-msg">{c.message}</span>
            </li>
          ))}
        </ul>
        <span class="gitlog-note">snapshot from the last site build — refreshed on deploy and nightly</span>
      </div>
    </div>
  )
}
