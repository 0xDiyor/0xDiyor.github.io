---
import type { Project } from '../data/projects';
import type { RepoMeta } from '../data/github';

interface Props {
  project: Project;
  meta?: RepoMeta | null;
}

const { project, meta = null } = Astro.props;
const url = project.github || project.demo || '#';
---

<a href={url} target="_blank" rel="noopener noreferrer" class="project-card">
  <div class="project-name">{project.name}</div>
  <p class="project-desc">{project.description}</p>
  <div class="project-tech">
    {project.tech.map((t) => <span>{t}</span>)}
  </div>
  {
    meta && (
      <div class="project-live">
        {meta.language && <span>{meta.language}</span>}
        {meta.stars > 0 && <span class="stars">{meta.stars}</span>}
        {meta.pushedAt && (
          <span>
            last commit <time datetime={meta.pushedAt}>{meta.pushedAt}</time>
          </span>
        )}
      </div>
    )
  }
</a>
